{
  "name": "@tokidevs/adachi",
  "version": "0.1.0",
  "description": "Production-ready React UI primitives and theme tokens — buttons, cards, inputs, modal, dropdown, and multi-mode theming (light, dark, neon, glass).",
  "license": "MIT",
  "author": "tokidevs",
  "repository": {
    "type": "git",
    "url": "https://github.com/tokidevs/adachi.git",
    "directory": "packages/adachi"
  },
  "bugs": {
    "url": "https://github.com/tokidevs/adachi/issues"
  },
  "homepage": "https://github.com/tokidevs/adachi#readme",
  "keywords": [
    "react",
    "design-system",
    "ui",
    "tailwind",
    "typescript",
    "components",
    "theming",
    "framer-motion"
  ],
  "sideEffects": [
    "**/*.css",
    "./dist/adachi.css"
  ],
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/adachi.css"
  },
  "scripts": {
    "build": "tsup && npm run build:css",
    "build:css": "tailwindcss -i ./src/styles/adachi.css -o ./dist/adachi.css --minify",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "focus-trap-react": "^11.0.4"
  },
  "peerDependencies": {
    "framer-motion": "^11 || ^12",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "framer-motion": "^12.38.0",
    "jsdom": "^27.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "tsup": "^8.5.0",
    "typescript": "~6.0.2",
    "vitest": "^3.2.4"
  }
}
